#ifndef SOLAR_TRACKER_SECRETS_H
#define SOLAR_TRACKER_SECRETS_H

// Copy this file to secrets.h and fill in your values (secrets.h is gitignored).

#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Realtime Database URL (e.g., "https://your-project.firebaseio.com")
// Get from Firebase Console → Realtime Database → Copy URL
#define FIREBASE_DATABASE_URL "https://your-project.firebaseio.com"

// Firebase Database Secret key (IMPORTANT: Used for REST API authentication)
// Get from Firebase Console → Project Settings → Service Accounts → Database Secrets
// Pass this in URL query: &auth=YOUR_SECRET_KEY
// Only needed if Firebase rules require authentication
#define FIREBASE_DATABASE_SECRET "YOUR_DATABASE_SECRET"

// TLS/SSL certificate verification
// 1 = TLS sans vérification du certificat (prototype/testing). 
// 0 = vérification stricte (production - requires certificate bundle)
#ifndef RTDB_TLS_INSECURE
#define RTDB_TLS_INSECURE 1
#endif

// Power threshold for "clean panel" detection (in Watts)
// Tune this based on your panel's expected output power
// Written to tracker/thresholds/cleaning_power_w
#ifndef CLEANING_POWER_W
#define CLEANING_POWER_W 10.0
#endif

// Enable local HTTP server with /data endpoint (for debugging/dashboard)
// GET http://<ESP32_IP>/data returns JSON with current sensor values
#ifndef ENABLE_HTTP_DATA_ENDPOINT
#define ENABLE_HTTP_DATA_ENDPOINT 1
#endif

// Enable debug logging for cloud operations
#ifndef DEBUG_CLOUD
#define DEBUG_CLOUD 1
#endif

#endif
