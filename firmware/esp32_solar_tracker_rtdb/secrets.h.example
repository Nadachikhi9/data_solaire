#ifndef SOLAR_TRACKER_SECRETS_H
#define SOLAR_TRACKER_SECRETS_H

// Copy this file to secrets.h and fill in your values (secrets.h is gitignored).

#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Realtime Database URL only (sans API key ni compte Firebase Auth).
// Même valeur que databaseURL dans lib/firebase_options.dart
#define FIREBASE_DATABASE_URL "https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com"

// 1 = TLS sans vérification du certificat (prototype). 0 = prévoir setCACert / bundle.
#ifndef RTDB_TLS_INSECURE
#define RTDB_TLS_INSECURE 1
#endif

// Written to tracker/thresholds/cleaning_power_w — tune for your panel (expected power in W when clean).
#ifndef CLEANING_POWER_W
#define CLEANING_POWER_W 10.0
#endif

// Set to 0 to disable HTTP GET /data (local HTML dashboard).
#ifndef ENABLE_HTTP_DATA_ENDPOINT
#define ENABLE_HTTP_DATA_ENDPOINT 1
#endif

#endif
